# --- Database (Neon PostgreSQL) ---
# Dev work uses the Neon *development* branch; production uses the *production* branch.

# App runtime (POOLED). Used by the pg driver adapter in src/lib/prisma.ts.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DBNAME?sslmode=verify-full"

# Migrations (DIRECT / non-pooled). Used by prisma.config.ts.
# Same as DATABASE_URL but without the "-pooler" segment in the host.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-full"

# --- Seed data ---
# Password for the seeded demo user (demo@devstash.io). Used by prisma/seed.ts.
# Optional locally (falls back to a throwaway value); set it to a real value
# in any shared/hosted environment.
DEMO_USER_PASSWORD="change-me-locally"

# --- Auth (NextAuth v5) ---
# Secret used to encrypt the JWT/session. Generate one with: npx auth secret
AUTH_SECRET=""

# GitHub OAuth app credentials.
# Create an app at https://github.com/settings/developers with the callback URL:
#   http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Optional. Base URL used to build absolute verification links. When unset,
# the origin of the incoming request is used (fine for local dev).
# AUTH_URL="http://localhost:3000"

# --- Email (Resend) ---
# API key from https://resend.com/api-keys — used to send verification emails.
RESEND_API_KEY=""

# Optional "from" address. Defaults to Resend's sandbox sender
# (onboarding@resend.dev), which only delivers to your Resend account email.
# Set a verified domain address for real delivery, e.g. "DevStash <noreply@yourdomain.com>".
# EMAIL_FROM="DevStash <onboarding@resend.dev>"

# Toggle the email-verification system. Defaults to enabled. Set to "false"
# (or "0") to disable — new users are auto-verified and can sign in without a
# link. Useful until a Resend sending domain is verified.
# EMAIL_VERIFICATION_ENABLED="true"

# --- Rate limiting (Upstash Redis) ---
# REST credentials from an Upstash Redis database (https://console.upstash.com).
# Used by src/lib/rate-limit.ts to throttle auth endpoints. Optional: when either
# is unset, rate limiting is disabled and all requests pass (fail-open) — fine
# for local dev. Set both in any shared/hosted environment.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
