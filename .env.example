# --- Database (Neon PostgreSQL) ---
# Dev work uses the Neon *development* branch; production uses the *production* branch.

# App runtime (POOLED). Used by the pg driver adapter in src/lib/prisma.ts.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DBNAME?sslmode=verify-full"

# Migrations (DIRECT / non-pooled). Used by prisma.config.ts.
# Same as DATABASE_URL but without the "-pooler" segment in the host.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-full"

# --- Seed data ---
# Password for the seeded demo user (demo@devstash.io). Used by prisma/seed.ts.
# Optional locally (falls back to a throwaway value); set it to a real value
# in any shared/hosted environment.
DEMO_USER_PASSWORD="change-me-locally"

# --- Auth (NextAuth v5) ---
# Secret used to encrypt the JWT/session. Generate one with: npx auth secret
AUTH_SECRET=""

# GitHub OAuth app credentials.
# Create an app at https://github.com/settings/developers with the callback URL:
#   http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
